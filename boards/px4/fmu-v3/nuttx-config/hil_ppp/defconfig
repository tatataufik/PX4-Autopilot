# ─────────────────────────────────────────────────────────────────────────────
# HIL-PPP DELTA — additions over the nsh base config
# ─────────────────────────────────────────────────────────────────────────────

# BSD components required by NET_TUN
CONFIG_ALLOW_BSD_COMPONENTS=y

# IPv4 network stack (minimal — no ARP, no Ethernet, no DHCP)
CONFIG_NET=y
CONFIG_NET_IPv4=y
CONFIG_NET_UDP=y
CONFIG_NET_UDP_CHECKSUMS=y
CONFIG_NET_UDP_WRITE_BUFFERS=y
CONFIG_NET_TCP=y
CONFIG_NET_TCPBACKLOG=y
CONFIG_NET_TCP_WRITE_BUFFERS=y
CONFIG_NET_ICMP=y
CONFIG_NET_ICMP_SOCKET=y
CONFIG_NET_NACTIVESOCKETS=8
CONFIG_NET_SOCKOPTS=y
CONFIG_NET_SOLINGER=y

# TUN virtual device — pppd creates a tun0 interface over the UART
CONFIG_NET_TUN=y
CONFIG_TUN_NINTERFACES=1
CONFIG_NET_TUN_PKTSIZE=1500

# netutils/pppd (pulls in netutils/chat automatically via Kconfig select)
CONFIG_NETUTILS_PPPD=y
CONFIG_NETUTILS_CHAT=y

# No Ethernet on STM32F427 — arm_netinitialize() must be a no-op.
# NETDEV_LATEINIT suppresses the arch call; our PPP/TUN device comes up later
# when ppp_link runs from rcS extras.txt.
CONFIG_NETDEV_LATEINIT=y

# ── USART2 = TELEM1 = /dev/ttyS1 — direct MAVLink ────────────────────────
# Non-PPP path: QGC / companion connects here directly (not through the tunnel).
# rc.board_ppp reconfigures TELEM1 to 921600 baud at runtime via mavlink_open_uart()
# (-b 921600 -r 80000). NuttX default is 115200 with TX=2048/RX=1024 (base config),
# same sizing as USART3 — both ports designed around 115200 (~11.5 KB/s) at build time.
# Flow control disabled — TELEM1 cables rarely wire CTS/RTS.

# ── USART3 = TELEM2 = /dev/ttyS2 — reconfigured for PPP ──────────────────
# 115200 baud, NO hardware flow control.
# Buffer sizes mirror satria-firmware fmuv3-hil (PPP_BUFSIZE_TX=2048,
# PPP_BUFSIZE_RX=1024) tuned for 115200 baud (~11.5 KB/s).
# TX=2048 handles MAVLink burst sends; RX=1024 avoids heap exhaustion
# from the "No buffer space" error seen at larger sizes on STM32F427.
CONFIG_USART3_BAUD=115200
# Flow control disabled — pppd uses nocrtscts
CONFIG_USART3_IFLOWCONTROL=n
CONFIG_USART3_OFLOWCONTROL=n
# RX DMA ring buffer: 1024 bytes (~89 ms headroom at 115200 baud)
CONFIG_USART3_RXBUFSIZE=1024
CONFIG_USART3_RXDMA=y
# TX buffer: 2048 bytes for MAVLink burst frames
CONFIG_USART3_TXBUFSIZE=2048
