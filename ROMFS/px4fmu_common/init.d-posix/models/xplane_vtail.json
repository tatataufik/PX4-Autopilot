# X-Plane DREF map — generic V-tail fixed-wing (5003_xplane_vtail)
#
# Ported from satria-firmware (ArduPlane) Tools/autotest/models/xplane_vtail.json.
# Channel numbers converted from ArduPlane (1-indexed servos) to PX4
# (0-indexed actuator_outputs.output[]):
#
#   PX4 channel 0  → aileron     (control allocator output)
#   PX4 channel 1  → v-tail right (PX4 control alloc pre-mixes elev−rud)
#   PX4 channel 2  → throttle
#   PX4 channel 3  → v-tail left  (PX4 control alloc pre-mixes elev+rud)
#
# X-Plane DREF mapping (ailerons are mirrored via "invert" since the
# PX4 control allocator emits a single aileron channel and we want
# X-Plane's left/right ailerons to deflect oppositely):
#
#   wing1r_ail1def  ← +CH0 (right aileron)
#   wing1l_ail1def  ← −CH0 (left aileron, invert:true)
#   vstab1_rud1def  ← CH1  (v-tail right ruddervator, mixer-applied)
#   vstab2_rud1def  ← CH3  (v-tail left ruddervator, mixer-applied)
#   ENGN_thro_use[0] ← CH2 (motor throttle 0..1)
#
# Override scheme (matches satria's working setup):
#   override_throttles       = 1   (PX4 owns throttle)
#   override_control_surfaces = 1  (PX4 owns surface DREFs)
#   override_joystick is NOT set — would otherwise zero the yoke axes
#   which feed back into surface positions on some X-Plane models.
#
# type "fixed"   : send value always (for X-Plane overrides)
# type "range"   : send output[channel] * range  (clamped 0..range, motors)
# type "angle"   : send output[channel] * range  (output is -1..1, servos)
# type "running" : send 1 when armed and output[channel] > 0.01, else 0
#
# range=20 matches ±20° deflection on the generic X-Plane V-tail model.

{
    "settings": { "debug": 0 },

    # Disable X-Plane's own throttle + surface logic so PX4 owns them.
    "sim/operation/override/override_throttles"        : { "type": "fixed", "value": 1 },
    "sim/operation/override/override_control_surfaces" : { "type": "fixed", "value": 1 },

    # Engine run state (must be 1 for X-Plane to accept ENGN_thro_use)
    "sim/flightmodel/engine/ENGN_running[0]" : { "type": "running", "channel": 2 },

    # Aileron — single PX4 channel drives both wings, left side inverted
    "sim/flightmodel/controls/wing1r_ail1def" : { "type": "angle", "range": 20.0, "channel": 0 },
    "sim/flightmodel/controls/wing1l_ail1def" : { "type": "angle", "range": 20.0, "channel": 0, "invert": true },

    # V-tail surfaces — direct angle mapping (PX4 control allocator
    # already mixes elevator+rudder onto these two ruddervator outputs).
    "sim/flightmodel/controls/vstab1_rud1def" : { "type": "angle", "range": 20.0, "channel": 1 },
    "sim/flightmodel/controls/vstab2_rud1def" : { "type": "angle", "range": 20.0, "channel": 3 },

    # Throttle (0.0 .. 1.0)
    "sim/flightmodel/engine/ENGN_thro_use[0]" : { "type": "range", "range": 1.0, "channel": 2 }
}
